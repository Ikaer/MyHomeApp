# Docling sidecar (PDF → Markdown with table structure)
# Set to http://localhost:8000 for local dev; http://myhomeapp-docling:8000 in Docker
DOCLING_URL=http://localhost:8000

# MyAnimeList API Configuration
# Get your client ID from: https://myanimelist.net/apiconfig
MAL_CLIENT_ID=your_mal_client_id_here
MAL_REDIRECT_URI=http://localhost:12344/api/anime/auth

# Data paths (Docker container paths)
DATA_PATH=/app/data
CONFIG_PATH=/app/config
LOGS_PATH=/app/logs

CRON_SECRET=your_cron_secret_key